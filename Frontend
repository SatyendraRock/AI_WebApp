<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEON PULSE // California 2026</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&family=Inter:wght@300;400;600;800&display=swap');

        :root {
            --neon-purple: #bf00ff;
            --neon-cyan: #00f2ff;
            --dark-bg: #050505;
        }

        body {
            background-color: var(--dark-bg);
            color: white;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        .font-heading { font-family: 'Syncopate', sans-serif; }

        .glass {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
        }

        .neon-text-purple { text-shadow: 0 0 20px rgba(191, 0, 255, 0.6); }
        .neon-border-cyan { border: 1px solid var(--neon-cyan); box-shadow: 0 0 15px rgba(0, 242, 255, 0.3); }

        .hero-gradient {
            background: radial-gradient(circle at 50% 50%, rgba(191, 0, 255, 0.15) 0%, rgba(5, 5, 5, 1) 70%);
        }

        .animate-pulse-slow {
            animation: pulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        @keyframes pulse {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 0.6; }
        }

        .lineup-card:hover img { transform: scale(1.1); transition: 0.5s ease; }
    </style>
</head>
<body>

    <!-- Nav -->
    <nav class="fixed top-0 w-full z-50 px-6 py-4">
        <div class="max-w-7xl mx-auto glass px-6 py-3 flex justify-between items-center">
            <div class="text-2xl font-heading font-bold tracking-tighter italic">
                NEON<span class="text-[var(--neon-cyan)]">PULSE</span>
            </div>
            <div class="hidden md:flex gap-8 font-semibold text-sm uppercase tracking-widest">
                <a href="#lineup" class="hover:text-[var(--neon-cyan)] transition">Lineup</a>
                <a href="#schedule" class="hover:text-[var(--neon-cyan)] transition">Schedule</a>
                <a href="#venue" class="hover:text-[var(--neon-cyan)] transition">Venue</a>
                <a href="#tickets" class="hover:text-[var(--neon-cyan)] transition">Tickets</a>
            </div>
            <a href="#tickets" class="bg-white text-black px-6 py-2 rounded-full font-bold hover:bg-[var(--neon-cyan)] transition-all transform hover:scale-105">
                GET TICKETS
            </a>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative min-h-screen flex items-center justify-center pt-20 overflow-hidden hero-gradient">
        <div class="absolute inset-0 opacity-20 pointer-events-none">
            <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-[var(--neon-purple)] rounded-full blur-[120px] animate-pulse-slow"></div>
            <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-[var(--neon-cyan)] rounded-full blur-[120px] animate-pulse-slow"></div>
        </div>

        <div class="relative z-10 text-center px-4" data-aos="zoom-out" data-aos-duration="1500">
            <div class="inline-block px-4 py-1 border border-[var(--neon-cyan)] rounded-full text-[var(--neon-cyan)] text-xs font-bold tracking-[0.3em] mb-6 uppercase">
                August 14-16 • Joshua Tree, CA
            </div>
            <h1 class="text-6xl md:text-9xl font-heading font-bold mb-6 leading-tight">
                THE FUTURE <br> <span class="text-transparent bg-clip-text bg-gradient-to-r from-[var(--neon-purple)] to-[var(--neon-cyan)]">OF SOUND</span>
            </h1>
            <p class="max-w-2xl mx-auto text-gray-400 text-lg md:text-xl mb-10 font-light leading-relaxed">
                Experience a 3-day immersive odyssey featuring world-class visual arts, 
                desert sunsets, and the global leaders of electronic music.
            </p>
            
            <!-- Countdown -->
            <div class="glass max-w-xl mx-auto p-6 mb-12">
                <p class="text-xs uppercase tracking-widest mb-4 text-[var(--neon-purple)] font-bold">Early Bird Ends In:</p>
                <div class="flex justify-center gap-8 text-3xl md:text-4xl font-heading" id="countdown">
                    <div><span id="hours">01</span><p class="text-[10px] uppercase mt-1">Hrs</p></div>
                    <div><span id="minutes">59</span><p class="text-[10px] uppercase mt-1">Min</p></div>
                    <div><span id="seconds">42</span><p class="text-[10px] uppercase mt-1">Sec</p></div>
                </div>
            </div>

            <div class="flex flex-col md:flex-row gap-4 justify-center">
                <a href="#tickets" class="px-10 py-4 bg-[var(--neon-purple)] rounded-full font-bold text-lg hover:shadow-[0_0_30px_rgba(191,0,255,0.5)] transition-all">BOOK EXPERIENCE</a>
                <a href="#lineup" class="px-10 py-4 glass rounded-full font-bold text-lg hover:bg-white/10 transition-all">VIEW LINEUP</a>
            </div>
        </div>
    </section>

    <!-- Artist Lineup -->
    <section id="lineup" class="py-24 px-6">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                <div>
                    <h2 class="text-5xl font-heading font-bold mb-4" data-aos="fade-right">THE LINEUP</h2>
                    <p class="text-gray-500 max-w-md">Curating the most influential names in Techno, House, and Ambient Audio-Visual experiences.</p>
                </div>
                <div class="text-[var(--neon-cyan)] font-heading text-xl tracking-tighter" data-aos="fade-left">
                    + 40 MORE ARTISTS
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Artist 1 -->
                <div class="lineup-card relative h-[500px] overflow-hidden rounded-[32px] group" data-aos="fade-up">
                    <img src="https://images.unsplash.com/photo-1470225620780-dba8ba36b745?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Artist">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-90"></div>
                    <div class="absolute bottom-8 left-8">
                        <p class="text-[var(--neon-cyan)] font-bold tracking-widest text-xs mb-2">HEADLINER // FRIDAY</p>
                        <h3 class="text-4xl font-heading font-bold">CYBER<br>PULSE</h3>
                    </div>
                </div>
                <!-- Artist 2 -->
                <div class="lineup-card relative h-[500px] overflow-hidden rounded-[32px] group" data-aos="fade-up" data-aos-delay="100">
                    <img src="https://images.unsplash.com/photo-1493225255756-d9584f8606e9?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Artist">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-90"></div>
                    <div class="absolute bottom-8 left-8">
                        <p class="text-[var(--neon-purple)] font-bold tracking-widest text-xs mb-2">HEADLINER // SATURDAY</p>
                        <h3 class="text-4xl font-heading font-bold">VOID<br>RUNNER</h3>
                    </div>
                </div>
                <!-- Artist 3 -->
                <div class="lineup-card relative h-[500px] overflow-hidden rounded-[32px] group" data-aos="fade-up" data-aos-delay="200">
                    <img src="https://images.unsplash.com/photo-1514525253361-b83f859b73c0?auto=format&fit=crop&q=80&w=800" class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700" alt="Artist">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-90"></div>
                    <div class="absolute bottom-8 left-8">
                        <p class="text-orange-500 font-bold tracking-widest text-xs mb-2">HEADLINER // SUNDAY</p>
                        <h3 class="text-4xl font-heading font-bold">SOLAR<br>ECHO</h3>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Tickets -->
    <section id="tickets" class="py-24 px-6 relative">
        <div class="max-w-7xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-5xl font-heading font-bold mb-4" data-aos="fade-up">SELECT YOUR PASS</h2>
                <p class="text-gray-400" data-aos="fade-up" data-aos-delay="100">All passes include full access to the festival grounds and art installations.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Tier 1 -->
                <div class="glass p-10 flex flex-col items-center text-center hover:border-[var(--neon-cyan)] transition-all" data-aos="fade-up">
                    <span class="text-xs font-bold tracking-widest text-gray-500 mb-4 uppercase">Early Bird</span>
                    <div class="text-5xl font-heading font-bold mb-6">$199</div>
                    <ul class="text-gray-400 space-y-4 mb-10 text-sm">
                        <li>3-Day Standard Entry</li>
                        <li>General Camping Access</li>
                        <li>Digital Souvenir NFT</li>
                    </ul>
                    <button class="w-full py-4 border border-white/20 rounded-xl font-bold hover:bg-white hover:text-black transition-all">SOLD OUT</button>
                </div>

                <!-- Tier 2 -->
                <div class="glass p-10 flex flex-col items-center text-center border-[var(--neon-purple)] scale-105 shadow-2xl relative" data-aos="fade-up" data-aos-delay="100">
                    <div class="absolute -top-4 bg-[var(--neon-purple)] text-xs font-bold px-4 py-1 rounded-full uppercase tracking-widest">Most Popular</div>
                    <span class="text-xs font-bold tracking-widest text-gray-500 mb-4 uppercase">Full Pass</span>
                    <div class="text-5xl font-heading font-bold mb-6">$299</div>
                    <ul class="text-gray-400 space-y-4 mb-10 text-sm">
                        <li>3-Day Priority Entry</li>
                        <li>Standard Camping Access</li>
                        <li>Free Shuttles from Joshua Tree</li>
                        <li>Limited Edition Poster</li>
                    </ul>
                    <button class="w-full py-4 bg-[var(--neon-purple)] rounded-xl font-bold hover:shadow-[0_0_20px_rgba(191,0,255,0.4)] transition-all">SELECT PASS</button>
                </div>

                <!-- Tier 3 -->
                <div class="glass p-10 flex flex-col items-center text-center hover:border-yellow-500 transition-all" data-aos="fade-up" data-aos-delay="200">
                    <span class="text-xs font-bold tracking-widest text-gray-500 mb-4 uppercase">VIP Infinity</span>
                    <div class="text-5xl font-heading font-bold mb-6">$599</div>
                    <ul class="text-gray-400 space-y-4 mb-10 text-sm">
                        <li>Backstage Lounge Access</li>
                        <li>Glamping Site Included</li>
                        <li>Open Bar (Select Hours)</li>
                        <li>Private Viewing Deck</li>
                    </ul>
                    <button class="w-full py-4 border border-white/20 rounded-xl font-bold hover:bg-white hover:text-black transition-all">SELECT PASS</button>
                </div>
            </div>
        </div>
    </section>

    <!-- Venue & Info (Split Layout) -->
    <section id="venue" class="py-24 glass mx-6 my-12 overflow-hidden">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
            <div data-aos="fade-right">
                <h2 class="text-4xl font-heading font-bold mb-8 italic">THE DESTINATION</h2>
                <div class="space-y-8">
                    <div class="flex gap-6">
                        <div class="w-12 h-12 flex-shrink-0 bg-white/5 rounded-full flex items-center justify-center">
                            <i data-lucide="map-pin" class="text-[var(--neon-cyan)]"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg mb-1">Cyber Basin, Joshua Tree</h4>
                            <p class="text-gray-400 text-sm leading-relaxed">A secluded natural amphitheater surrounded by ancient rock formations and the clearest starlight in California.</p>
                        </div>
                    </div>
                    <div class="flex gap-6">
                        <div class="w-12 h-12 flex-shrink-0 bg-white/5 rounded-full flex items-center justify-center">
                            <i data-lucide="car" class="text-[var(--neon-cyan)]"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg mb-1">Parking & Transit</h4>
                            <p class="text-gray-400 text-sm leading-relaxed">Pre-booked parking passes required. 24/7 Neon Shuttle running from Palm Springs and Downtown LA.</p>
                        </div>
                    </div>
                    <div class="flex gap-6">
                        <div class="w-12 h-12 flex-shrink-0 bg-white/5 rounded-full flex items-center justify-center">
                            <i data-lucide="info" class="text-[var(--neon-cyan)]"></i>
                        </div>
                        <div>
                            <h4 class="font-bold text-lg mb-1">Festival Rules</h4>
                            <p class="text-gray-400 text-sm leading-relaxed">No single-use plastics. Zero trace policy. Hydration stations available throughout the basin.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="relative rounded-3xl overflow-hidden h-[500px]" data-aos="fade-left">
                <img src="https://images.unsplash.com/photo-1533174072545-7a4b6ad7a6c3?auto=format&fit=crop&q=80&w=800" class="w-full h-full object-cover" alt="Venue">
                <div class="absolute inset-0 bg-[var(--neon-purple)]/20 mix-blend-overlay"></div>
            </div>
        </div>
    </section>

    <!-- Testimonials / Social Proof -->
    <section class="py-24 px-6 overflow-hidden">
        <div class="max-w-7xl mx-auto flex flex-col items-center">
            <h3 class="text-sm font-bold tracking-[0.4em] text-[var(--neon-cyan)] mb-12 uppercase">Join 20k Pulse-Seekers</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 italic text-lg text-center font-light">
                <div data-aos="fade-up">
                    <p>"The most visually stunning event I've ever attended. It felt like living in TRON."</p>
                    <span class="block mt-4 not-italic font-bold text-xs text-gray-500 uppercase tracking-widest">— Rolling Stone</span>
                </div>
                <div data-aos="fade-up" data-aos-delay="100">
                    <p>"A masterclass in immersive festival design and curation."</p>
                    <span class="block mt-4 not-italic font-bold text-xs text-gray-500 uppercase tracking-widest">— Pitchfork</span>
                </div>
                <div data-aos="fade-up" data-aos-delay="200">
                    <p>"Neon Pulse is the only place where the desert and the future collide."</p>
                    <span class="block mt-4 not-italic font-bold text-xs text-gray-500 uppercase tracking-widest">— Billboard</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="pt-24 pb-12 px-6 border-t border-white/5">
        <div class="max-w-7xl mx-auto">
            <div class="flex flex-col md:flex-row justify-between items-start gap-12 mb-20">
                <div class="max-w-sm">
                    <div class="text-3xl font-heading font-bold mb-6 tracking-tighter">
                        NEON<span class="text-[var(--neon-cyan)]">PULSE</span>
                    </div>
                    <p class="text-gray-500 text-sm leading-relaxed mb-6">
                        Redefining the festival experience through the lens of technology and natural beauty. Join the pulse.
                    </p>
                    <div class="flex gap-4">
                        <a href="#" class="w-10 h-10 glass flex items-center justify-center hover:bg-[var(--neon-cyan)] hover:text-black transition"><i data-lucide="instagram" class="w-5 h-5"></i></a>
                        <a href="#" class="w-10 h-10 glass flex items-center justify-center hover:bg-[var(--neon-cyan)] hover:text-black transition"><i data-lucide="twitter" class="w-5 h-5"></i></a>
                        <a href="#" class="w-10 h-10 glass flex items-center justify-center hover:bg-[var(--neon-cyan)] hover:text-black transition"><i data-lucide="youtube" class="w-5 h-5"></i></a>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-16">
                    <div>
                        <h5 class="font-bold mb-6 text-xs uppercase tracking-widest">Festival</h5>
                        <ul class="text-gray-500 text-sm space-y-4">
                            <li><a href="#" class="hover:text-white transition">Lineup</a></li>
                            <li><a href="#" class="hover:text-white transition">Schedule</a></li>
                            <li><a href="#" class="hover:text-white transition">Art & Visuals</a></li>
                        </ul>
                    </div>
                    <div>
                        <h5 class="font-bold mb-6 text-xs uppercase tracking-widest">Support</h5>
                        <ul class="text-gray-500 text-sm space-y-4">
                            <li><a href="#" class="hover:text-white transition">FAQ</a></li>
                            <li><a href="#" class="hover:text-white transition">Parking</a></li>
                            <li><a href="#" class="hover:text-white transition">Contact</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="text-center text-gray-700 text-[10px] uppercase tracking-widest font-bold">
                &copy; 2026 Neon Pulse Music Festival. All Rights Reserved. Designed for the Future.
            </div>
        </div>
    </footer>

    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        // Initialize Icons
        lucide.createIcons();
        
        // Initialize Animations
        AOS.init({
            duration: 1000,
            once: true,
            easing: 'ease-out-cubic'
        });

        // Simple Countdown Logic (2-hour simulated timer)
        let hours = 1;
        let minutes = 59;
        let seconds = 42;

        function updateCountdown() {
            seconds--;
            if (seconds < 0) {
                seconds = 59;
                minutes--;
            }
            if (minutes < 0) {
                minutes = 59;
                hours--;
            }
            
            document.getElementById('hours').innerText = String(hours).padStart(2, '0');
            document.getElementById('minutes').innerText = String(minutes).padStart(2, '0');
            document.getElementById('seconds').innerText = String(seconds).padStart(2, '0');
            
            if (hours === 0 && minutes === 0 && seconds === 0) {
                clearInterval(timer);
            }
        }
        const timer = setInterval(updateCountdown, 1000);
    </script>
</body>
</html>
