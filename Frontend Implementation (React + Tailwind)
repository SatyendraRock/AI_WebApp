import { useState } from 'react';
import { supabase } from './supabaseClient'; // Initialize Supabase
import { PayPalButtons } from "@paypal/react-paypal-js";
import QRCode from 'react-qr-code';

export default function TicketSystem() {
  const [step, setStep] = useState(1); // 1: Auth, 2: Info/ID, 3: Payment, 4: Ticket
  const [email, setEmail] = useState('');
  const [loading, setLoading] = useState(false);
  const [formData, setFormData] = useState({ name: '', phone: '', address: '', idFile: null });

  // 1. EMAIL OTP SIGN UP/LOGIN
  const handleLogin = async () => {
    setLoading(true);
    const { error } = await supabase.auth.signInWithOtp({ email });
    if (error) alert(error.message);
    else alert('Check your email for the OTP link!');
    setLoading(false);
  };

  // 2. FILE UPLOAD & TICKET BOOKING
  const handleBooking = async (details) => {
    // Upload Gov ID to Secure Storage
    const file = formData.idFile;
    const fileExt = file.name.split('.').pop();
    const fileName = `${Math.random()}.${fileExt}`;
    const { data: uploadData } = await supabase.storage
      .from('gov-ids')
      .upload(fileName, file);

    // Save Booking to DB
    const { data: booking } = await supabase.from('bookings').insert([{
      user_email: email,
      full_name: formData.name,
      id_document_url: uploadData.path,
      payment_id: details.id,
      status: 'PAID'
    }]).select();

    setStep(4); // Move to Success/QR Step
  };

  return (
    <div className="min-h-screen bg-[#050505] text-white p-8">
      <div className="max-w-xl mx-auto glass p-8 border border-white/10">
        
        {step === 1 && (
          <div className="text-center">
            <h2 className="text-3xl font-heading mb-6">SECURE ACCESS</h2>
            <input 
              type="email" 
              placeholder="Enter Email" 
              className="w-full bg-white/5 border border-white/20 p-4 rounded-xl mb-4"
              onChange={(e) => setEmail(e.target.value)}
            />
            <button onClick={handleLogin} className="w-full py-4 bg-cyan-500 rounded-xl font-bold">
              SEND MAGIC LINK
            </button>
          </div>
        )}

        {step === 2 && (
          <div className="space-y-4">
            <h2 className="text-2xl font-heading">ATTENDEE INFORMATION</h2>
            <input type="text" placeholder="Full Name" className="w-full bg-white/5 border border-white/20 p-4 rounded-xl" 
                   onChange={(e) => setFormData({...formData, name: e.target.value})}/>
            <input type="file" className="w-full text-sm text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:bg-cyan-500"
                   onChange={(e) => setFormData({...formData, idFile: e.target.files[0]})}/>
            <button onClick={() => setStep(3)} className="w-full py-4 bg-purple-600 rounded-xl font-bold">PROCEED TO PAYMENT</button>
          </div>
        )}

        {step === 3 && (
          <div className="text-center">
            <h2 className="text-2xl font-heading mb-6">PAYMENT</h2>
            <PayPalButtons 
              createOrder={(data, actions) => actions.order.create({ purchase_units: [{ amount: { value: "299.00" } }] })}
              onApprove={(data, actions) => actions.order.capture().then(handleBooking)}
            />
          </div>
        )}

        {step === 4 && (
          <div className="text-center">
            <h2 className="text-2xl font-heading text-green-400">BOOKING CONFIRMED!</h2>
            <div className="my-8 bg-white p-4 inline-block rounded-xl">
              <QRCode value={`TICKET-ID-PULSE-2026-${Math.random()}`} size={180} />
            </div>
            <p className="text-gray-400">Your unique QR code is ready. Please present this along with your physical ID at the gate.</p>
          </div>
        )}

      </div>
    </div>
  );
}
